{
  "name": "@bitcode/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Tracing helpers for Bitcode (JS build).",
  "main": "src/observability.ts",
  "types": "src/observability.ts",
  "exports": {
    ".": {
      "require": "./src/observability.ts",
      "default": "./src/observability.ts"
    },
    "./src/observability": {
      "require": "./src/observability.ts",
      "default": "./src/observability.ts"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "@bitcode/logger": "workspace:*",
    "@bitcode/streams": "workspace:*",
    "@bitcode/sentry": "workspace:*",
    "@bitcode/errors": "workspace:*"
  }
}
