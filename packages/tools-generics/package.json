{
  "name": "@bitcode/tools-generics",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.js"
    },
    "./execution": {
      "types": "./src/execution/index.ts",
      "default": "./src/execution/index.js"
    },
    "./doc-code-tool": {
      "types": "./src/doc-code-tool/index.ts",
      "default": "./src/doc-code-tool/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bitcode/doc-comment": "workspace:*",
    "@bitcode/doc-code": "workspace:*",
    "@bitcode/execution-generics": "workspace:*",
    "@bitcode/prompts": "workspace:*",
    "@bitcode/registry": "workspace:*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
