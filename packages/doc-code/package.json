{
  "name": "@bitcode/doc-code",
  "version": "1.0.0",
  "description": "Runtime documentation injection system - makes docs available IN CODE",
  "main": "src/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.js"
    },
    "./loader": {
      "types": "./src/loaders/doc-code-tool-loader.ts",
      "default": "./src/loaders/doc-code-tool-loader.js"
    },
    "./transformDocCodeTools": {
      "types": "./src/transformDocCodeTools.ts",
      "default": "./src/transformDocCodeTools.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "transform": "ts-node scripts/apply-doc-code-transform.ts"
  },
  "keywords": [
    "documentation",
    "runtime",
    "injection",
    "proto",
    "metadata"
  ],
  "dependencies": {
    "@bitcode/doc-comment": "workspace:*",
    "glob": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "@types/webpack": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0"
  }
}
