{
  "name": "@bitcode/notion",
  "version": "1.0.0",
  "description": "Notion API integration package for Bitcode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "type-check": "pnpm run typecheck"
  },
  "dependencies": {
    "@bitcode/supabase": "workspace:*",
    "@bitcode/logger": "workspace:*",
    "@notionhq/client": "^2.3.0",
    "notion-md-crawler": "^0.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "eslint": "^8.0.0"
  }
}
