{
  "name": "@bitcode/orm",
  "version": "1.0.0",
  "description": "Bitcode ORM - Database access layer with AssetPack evidence vector storage",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "codegen:db": "ts-node --transpile-only scripts/generate-db-types.ts",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests",
    "generate-types": "supabase gen types typescript --local > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "10.9.2",
    "typescript": "^5.0.0"
  }
}
