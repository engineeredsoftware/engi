{
  "name": "@engi/test-intelligence",
  "version": "0.0.0",
  "description": "Unified test intelligence system for fixtures, mocks, dryrun, and Storybook",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
