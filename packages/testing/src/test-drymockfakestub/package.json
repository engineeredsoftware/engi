    "vitest": "^1.1.0",
    "webpack": "^5.89.0"
  },
  "peerDependencies": {
    "@storybook/react": "^7.6.0",
    "react": "^18.2.0"
  },
  "peerDependenciesMeta": {
    "@storybook/react": {
      "optional": true
    }
  }
}
