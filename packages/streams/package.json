{
  "name": "@bitcode/streams",
  "version": "0.1.0",
  "private": true,
  "description": "Streaming helpers (JS stub build).",
  "main": "src/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./src/streams": {
      "types": "./src/streams.ts",
      "require": "./src/streams.js",
      "default": "./src/streams.js"
    },
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bitcode/logger": "workspace:*",
    "@bitcode/supabase": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
