{
  "name": "@bitcode/mcp-server",
  "version": "0.0.1", 
  "private": true,
  "description": "Engi's Model Context Protocol server - The ultimate engineering intelligence platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:mcp": "jest --config jest.config.mcp.js",
    "test:mcp:watch": "jest --config jest.config.mcp.js --watch",
    "test:mcp:ci": "jest --config jest.config.mcp.js --ci --coverage --watchAll=false",
    "test:mcp:performance": "jest --config jest.config.mcp.js --testNamePattern='Performance'",
    "test:mcp:security": "jest --config jest.config.mcp.js --testNamePattern='Security'",
    "test:mcp:customer": "jest --config jest.config.mcp.js --testNamePattern='Customer'",
    "test:dry-run": "DRY_RUN_MODE=true npm run test:mcp",
    "test:report": "npm run test:mcp:ci && echo 'Test reports available in tmp/test-reports/'",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "docs:generate": "tsx src/docs/mcp-spec-generator.ts",
    "docs:openapi": "tsx src/docs/openapi-build.ts",
    "docs:serve": "http-server docs/mcp -p 8080 -o",
    "docs:build": "npm run docs:generate && npm run docs:openapi && npm run docs:serve",
    "prepublishOnly": "npm run build && npm run docs:generate && npm run docs:openapi"
  },
  "dependencies": {
    "@bitcode/pipelines-generics": "workspace:*",
    "@bitcode/pipeline-deliverable": "workspace:*",
    "@bitcode/supabase": "workspace:*",
    "@bitcode/auth": "workspace:*",
    "@bitcode/credits": "workspace:*",
    "@bitcode/logger": "workspace:*",
    "@bitcode/observability": "workspace:*",
    "@bitcode/networking": "workspace:*",
    "@bitcode/security": "workspace:*",
    "@bitcode/mcp": "workspace:*",
    "@bitcode/errors": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4",
    "ws": "^8.14.2",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "tsx": "^4.6.0",
    "http-server": "^14.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "jest-html-reporters": "^3.1.0",
    "jest-junit": "^16.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol", 
    "ai",
    "engineering",
    "pipelines",
    "automation"
  ]
}
