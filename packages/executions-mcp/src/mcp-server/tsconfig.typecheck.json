{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "../../../..",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "exclude": [
    "dist",
    "node_modules",
    "src/__tests__/**/*",
    "src/tools/jira-tools.ts",
    "src/tools/monitoring-tools.ts",
    "src/tools/orchestration-tools.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
