{
  "name": "@bitcode/prompts",
  "version": "1.0.0",
  "description": "The fundamental prompt primitives package for the Bitcode prompt system",
  "private": true,
  "main": "src/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.js"
    },
    "./prompt": {
      "types": "./src/prompt.ts",
      "default": "./src/prompt.js"
    },
    "./parts/PromptPart": {
      "types": "./src/parts/PromptPart.ts",
      "default": "./src/parts/PromptPart.js"
    },
    "./execution/PromptExecution": {
      "types": "./src/execution/PromptExecution.ts",
      "default": "./src/execution/PromptExecution.js"
    },
    "./raw_promptparts/*": {
      "types": "./src/raw_promptparts/*.ts",
      "default": "./src/raw_promptparts/*.js"
    },
    "./formatters": {
      "types": "./src/formatters/index.d.ts",
      "default": "./src/formatters/index.js"
    },
    "./formatters/*": {
      "types": "./src/formatters/*.d.ts",
      "default": "./src/formatters/*.js"
    },
    "./package.json": "./package.json"
  },
  
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark": "tsx src/benchmarking/cli.ts benchmark",
    "benchmark:all": "tsx src/benchmarking/cli.ts benchmark:all",
    "benchmark:evolve": "tsx src/benchmarking/cli.ts benchmark:evolve",
    "benchmark:report": "tsx src/benchmarking/cli.ts benchmark:report"
  },
  "keywords": [
    "prompts",
    "prompt-engineering",
    "primitives",
    "bitcode"
  ],
  "author": "Bitcode Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/engineeredsoftware/bitcode.git",
    "directory": "packages/prompts"
  },
  "dependencies": {
    "@bitcode/registry": "workspace:*",
    "@bitcode/doc-comment": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.11.5",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.7.0",
    "glob": "^10.3.10"
  }
}
