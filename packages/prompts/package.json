{
  "name": "@engi/prompts",
  "version": "1.0.0",
  "description": "The fundamental prompt primitives package for the Engi engineering system",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./raw_promptparts/*": "./src/raw_promptparts/*.ts",
    "./package.json": "./package.json"
  },
  
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark": "tsx src/benchmarking/cli.ts benchmark",
    "benchmark:all": "tsx src/benchmarking/cli.ts benchmark:all",
    "benchmark:evolve": "tsx src/benchmarking/cli.ts benchmark:evolve",
    "benchmark:report": "tsx src/benchmarking/cli.ts benchmark:report"
  },
  "keywords": [
    "prompts",
    "prompt-engineering",
    "primitives",
    "engi"
  ],
  "author": "Engi Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/engi/engi.git",
    "directory": "packages/prompts"
  },
  "dependencies": {
    "@engi/registry": "workspace:*",
    "@engi/doc-comment": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.11.5",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.7.0",
    "glob": "^10.3.10"
  }
