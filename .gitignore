# Ignore pnpm temp workspaces
**/.pnpm-home/
**/dist/**

# Ignore accidental TS build outputs in packages (source lives in TS)
packages/**/src/**/*.js
packages/**/src/**/*.js.map
packages/**/__tests__/**/*.js

# Prevent accidental JS emission alongside TS in apps
# Admin app
admin/__tests__/**/*.js
admin/app/**/*.js
admin/components/**/*.js
admin/lib/**/*.js
admin/middleware.js

# UAPI app
uapi/__tests__/**/*.js
uapi/tests/**/*.js
uapi/app/**/*.js
uapi/components/**/*.js
uapi/lib/**/*.js
uapi/middleware/**/*.js
uapi/middleware.js

# UI registry example JS (generated)
uapi/components/ui/apps/**/example/**/*.js
uapi/components/ui/apps/www/registry/**/example/**/*.js

# Shadcn test fixtures and internal JS helpers
uapi/components/ui/packages/shadcn/test/**/*.js
uapi/components/ui/packages/shadcn/src/utils/**/*.js


