# Root development environment example.
# Copy to `.env.local` and fill local values. Keep populated values untracked.

BITCODE_BITCOIN_OAUTH_ALLOWED_REDIRECT_ORIGINS=<allowed OAuth redirect origins>
BITCODE_BITCOIN_OAUTH_ALLOWED_REDIRECT_URIS=<allowed OAuth redirect URIs>
BITCODE_BITCOIN_OAUTH_CLIENT_ID=<Bitcode Bitcoin OAuth client ID>
BITCODE_BITCOIN_OAUTH_CLIENT_SECRET=<Bitcode Bitcoin OAuth client secret>
BITCODE_BITCOIN_OAUTH_SUPABASE_CALLBACK_URL=<Supabase auth callback URL>
BITCODE_DEBUG_REGISTRIES=false
BITCODE_DEBUG_STOP_AFTER_PLAN=false
BITCODE_EXECUTION_DEBUG=false
BITCODE_LLM_MODEL=<default Bitcode LLM model>
BITCODE_LLM_PROVIDER=<default Bitcode LLM provider>
BITCODE_LOG_FULL_PROMPTS=false
BITCODE_LOG_FULL_PROMPTS_CORRELATION_IDS=
BITCODE_LOG_FULL_TRACES=false
BITCODE_LOG_TO_FILE=false
BITCODE_LOG_TRACES=false
BITCODE_MOCK_EXA=false
BITCODE_WRITE_PROMPT_IO=false
BITCODE_WRITE_STEP_TRACES=false
GEMINI_API_KEY=<Gemini API key>
GOOGLE_API_KEY=<Google API key>
GOOGLE_GENERATIVE_AI_API_KEY=<Google Generative AI API key>
LOG_LEVEL=info
NEXT_PUBLIC_COMING_SOON=false
NEXT_PUBLIC_CONVERSATION_SECTION=false
NEXT_PUBLIC_CONVERSATIONS_WIDGET=false
NEXT_PUBLIC_DISABLE_CONVERSATIONS_ROUTE=false
NEXT_PUBLIC_DISABLE_USING=false
NEXT_PUBLIC_INVISIBLE_INTERFACES_GROUP=false
NEXT_PUBLIC_LIGHTPAPER_BANNER=false
NEXT_PUBLIC_NAV_BAR=true
NEXT_PUBLIC_NOTIFICATIONS_WIDGET=true
NEXT_PUBLIC_SIDEBAR_LEFT=true
NEXT_PUBLIC_SOFT_LAUNCH=false
NEXT_PUBLIC_SUPABASE_ANON_KEY=<Supabase anon key>
NEXT_PUBLIC_SUPABASE_URL=<Supabase project URL>
SUPABASE_ANON_KEY=<Supabase anon key>
SUPABASE_DB_URL=<Supabase Postgres connection string for data-health checks>
SUPABASE_JWT_SECRET=<Supabase JWT secret>
SUPABASE_PUBLISHABLE_KEY=<Supabase publishable key>
SUPABASE_SECRET_KEY=<Supabase secret key>
SUPABASE_SERVICE_ROLE_KEY=<Supabase service role key>
SUPABASE_URL=<Supabase project URL>
