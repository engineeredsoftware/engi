      "@bitcode/prompts": ["packages/prompts/src/index.ts"],
      "@bitcode/system_prompt.txt": ["packages/prompts/src/system_prompt.txt"],
      "@bitcode/responses": ["packages/networking/src/responses.ts"],
      "@bitcode/sse": ["packages/networking/src/sse.ts"],
