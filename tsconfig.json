      "@bitcode/models": ["packages/models/src/index.ts"],
      "@bitcode/telemetry": ["packages/observability/src/telemetry.ts"],
      "@bitcode/dryrun": ["packages/observability/src/dryrun.ts"],
      "@bitcode/dryrun/*": ["packages/observability/src/dryrun/*"],
      "@bitcode/dockerUtils": ["packages/docker/src/index.ts"],
