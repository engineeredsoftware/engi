      "@bitcode/supabase": ["packages/supabase/src/index.ts"],
      // Git helpers alias (defined earlier; keep only one canonical mapping)
    "@/lib/validation/validationOTFAdherencePhaseModule": ["packages/validation/validationOTFAdherencePhaseModule.ts"],
    "@/lib/mcp/validation": ["packages/executions-mcp/src/index.ts"],
      "@bitcode/web-search": ["packages/web-search/src/index.ts"],
      
      "@bitcode/obfuscate": ["packages/obfuscate-generics/src/index.ts"],
