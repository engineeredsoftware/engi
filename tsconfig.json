      "@engi/dryrun": ["packages/observability/src/dryrun.ts"],
      "@engi/dryrun/*": ["packages/observability/src/dryrun/*"],
      "@engi/dockerUtils": ["packages/docker/src/index.ts"],
      "@engi/supabase": ["packages/supabase/src/index.ts"],
