# Simple image to run the queue-polling worker inside Kubernetes.
# We reuse the same codebase but set the ENTRYPOINT to long-runner-worker.ts

FROM node:20-slim AS base

WORKDIR /app

COPY uapi ./uapi

RUN npm install -g pnpm@8 && pnpm --filter uapi... install --prod --frozen-lockfile

FROM node:20-slim
WORKDIR /app
COPY --from=base /app /app
ENV NODE_ENV=production TZ=UTC POLL_INTERVAL_MS=2000

EXPOSE 9090

ENTRYPOINT ["npx", "ts-node", "uapi/scripts/long-runner-worker.ts"]
