  return {
    receipts: [issuanceReceipt, provenanceReceipt, sufficiencyReceipt, policyReceipt],
    decisionSurface: {
      claimedEvidence,
      measuredEvidence,
      policyRestrictions,
      receiptRefs: [issuanceReceipt.receiptId, provenanceReceipt.receiptId, sufficiencyReceipt.receiptId, policyReceipt.receiptId],
