+- `/Users/garrettmaring/Developer/ENGI/ENGI_SPEC_V15_SYSTEM_PARITY_MATRIX.md`
+- `src/engi-demo.js`
+- `src/realization-profile.js`
+- `src/settlement-structs.js`
+- `server.js`
+- `public/app.js`
+- `public/index.html`
+- `README.md`
+- `test/core.test.js`
+- `test/api.test.js`
+- `test/e2e.test.js`
+- `HOST_CAPABILITIES.md`
+- `HOST_CAPABILITIES.json`
+
+---
+
