{
  "name": "bitcode-uapi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=21"
  },
  "scripts": {
    "dev": "pnpm -w --filter @bitcode/doc-code build && pnpm dev:local",
    "dev:remote": "next dev --hostname 127.0.0.1",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "dev:local": "supabase start & pnpm dev:remote",
    "dev:stop": "supabase stop",
    "dev:down": "pnpm dev:stop",
    "dev:restart": "pnpm dev:down && pnpm dev:local",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e:api": "playwright test tests/e2e/api.e2e.test.ts",
    "test:e2e:ui": "playwright test",
    "test:e2e:commercial-mvp": "START_STORYBOOK=false NEXT_PUBLIC_MASTER_MOCK_MODE=true NEXT_PUBLIC_ENABLE_MOCKS=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES_SCENARIO=demo NEXT_PUBLIC_MOCK_SCENARIO=demo NEXT_PUBLIC_MOCK_GITHUB_ACCOUNTS=true NEXT_PUBLIC_MOCK_GITHUB_REPOS=true NEXT_PUBLIC_MOCK_GITHUB_BRANCHES=true NEXT_PUBLIC_MOCK_GITHUB_COMMITS=true NEXT_PUBLIC_MOCK_CHAT_STREAM=true NEXT_PUBLIC_MOCK_CHAT_SCENARIO=demo playwright test tests/e2e/commercial-mvp*.spec.ts --project=laptop --workers=1",
    "test:e2e:terminal-ux": "START_STORYBOOK=false NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 NEXT_PUBLIC_SUPABASE_ANON_KEY=mock-anon-key NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=mock-publishable-key NEXT_PUBLIC_MASTER_MOCK_MODE=true NEXT_PUBLIC_ENABLE_MOCKS=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES_SCENARIO=demo NEXT_PUBLIC_MOCK_SCENARIO=demo NEXT_PUBLIC_MOCK_GITHUB_ACCOUNTS=true NEXT_PUBLIC_MOCK_GITHUB_REPOS=true NEXT_PUBLIC_MOCK_GITHUB_BRANCHES=true NEXT_PUBLIC_MOCK_GITHUB_COMMITS=true NEXT_PUBLIC_MOCK_CHAT_STREAM=true NEXT_PUBLIC_MOCK_CHAT_SCENARIO=demo playwright test tests/e2e/commercial-mvp.terminal-ux.spec.ts --project=laptop --workers=1",
    "test:e2e:v32-browser-proof": "START_STORYBOOK=false NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 NEXT_PUBLIC_SUPABASE_ANON_KEY=mock-anon-key NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=mock-publishable-key NEXT_PUBLIC_MASTER_MOCK_MODE=true NEXT_PUBLIC_ENABLE_MOCKS=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES_SCENARIO=demo NEXT_PUBLIC_MOCK_SCENARIO=demo NEXT_PUBLIC_MOCK_GITHUB_ACCOUNTS=true NEXT_PUBLIC_MOCK_GITHUB_REPOS=true NEXT_PUBLIC_MOCK_GITHUB_BRANCHES=true NEXT_PUBLIC_MOCK_GITHUB_COMMITS=true NEXT_PUBLIC_MOCK_CHAT_STREAM=true NEXT_PUBLIC_MOCK_CHAT_SCENARIO=demo playwright test tests/e2e/bitcode-browser-accessibility-responsive-proof.spec.ts --project=laptop --workers=1",
    "test:e2e:browser-proof": "START_STORYBOOK=false NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 NEXT_PUBLIC_SUPABASE_ANON_KEY=mock-anon-key NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=mock-publishable-key NEXT_PUBLIC_MASTER_MOCK_MODE=true NEXT_PUBLIC_ENABLE_MOCKS=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES=true NEXT_PUBLIC_MOCK_USER_AUXILLARIES_SCENARIO=demo NEXT_PUBLIC_MOCK_SCENARIO=demo NEXT_PUBLIC_MOCK_GITHUB_ACCOUNTS=true NEXT_PUBLIC_MOCK_GITHUB_REPOS=true NEXT_PUBLIC_MOCK_GITHUB_BRANCHES=true NEXT_PUBLIC_MOCK_GITHUB_COMMITS=true NEXT_PUBLIC_MOCK_CHAT_STREAM=true NEXT_PUBLIC_MOCK_CHAT_SCENARIO=demo playwright test tests/e2e/bitcode-browser-proof.spec.ts --project=laptop --workers=1",
    "test:e2e:visual": "playwright test tests/e2e/**/*.visual.spec.ts",
    "test:e2e:onboarding": "START_STORYBOOK=false USE_API_MOCK=true playwright test tests/e2e/onboarding.visual.spec.ts tests/e2e/account.onboarding.visual.spec.ts --timeout=120000",
    "test:e2e:onboarding-first-step": "START_STORYBOOK=false USE_API_MOCK=true playwright test tests/e2e/onboarding-first-step.spec.ts --timeout=120000",
    "sync-asset-pack-evidence-embeddings": "ts-node scripts/sync-asset-pack-evidence-embeddings.ts",
    "codemod:trace-routes": "node scripts/trace-route-codemod.js",
    "dev:staging": "BITCODE_UAPI_ENV_FILE=../.env.local BITCODE_ENABLE_PIPELINE_HARNESS_API=1 BITCODE_PIPELINE_HARNESS_REQUIRE_REAL_INFERENCE=1 BITCODE_ASSET_PACK_REAL_INFERENCE=1 BITCODE_ASSET_PACK_REAL_INFERENCE_PROFILE=bounded BITCODE_PIPELINE_HARNESS_MAX_RUNTIME_MS=600000 next dev --hostname 127.0.0.1",
    "generate-doc-screenshot-stubs": "node ../scripts/generate-doc-screenshot-stubs.js",
    "capture-doc-screenshots": "node ../scripts/capture-doc-screenshots.js",
    "complete-doc-stories": "node ../scripts/complete-doc-stories.js"
  },
