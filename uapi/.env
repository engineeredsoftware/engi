# Example environment values for local Engi development.
# Copy these into an untracked .env.local file and replace placeholders with real credentials.

# Core AI + integration keys -------------------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
PINECONE_API_KEY=YOUR_PINECONE_API_KEY
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY
AUTH_GITHUB_ID=YOUR_GITHUB_OAUTH_CLIENT_ID
AUTH_GITHUB_SECRET=YOUR_GITHUB_OAUTH_CLIENT_SECRET
GITHUB_ENGI_APP_CLIENT_SECRET=YOUR_GITHUB_APP_CLIENT_SECRET
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
NOTION_INTEGRATION_TOKEN=YOUR_NOTION_INTEGRATION_TOKEN
HF_HUB_ENABLE_HF_TRANSFER=1
GROQ_API_KEY=YOUR_GROQ_API_KEY
REPLICATE_API_TOKEN=YOUR_REPLICATE_API_TOKEN
TOKENIZERS_PARALLELISM=true
SCW_ACCESS_KEY=YOUR_SCALEWAY_ACCESS_KEY
SCW_SECRET_KEY=YOUR_SCALEWAY_SECRET_KEY
SCW_DEFAULT_ORGANIZATION_ID=YOUR_SCALEWAY_ORGANIZATION_ID
SCW_DEFAULT_PROJECT_ID=YOUR_SCALEWAY_PROJECT_ID
INSTALLTION_ID=YOUR_INSTALLATION_ID
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_GENERATIVE_AI_API_KEY
DEBUG=true
ENGI_LOG_FULL_PROMPTS=1
ENGI_LOG_FULL_PROMPTS_CORRELATION_IDS=

# Supabase configuration ------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY
SUPABASE_AUTH_GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
SUPABASE_AUTH_GITHUB_CLIENT_ID=YOUR_GITHUB_OAUTH_CLIENT_ID
SUPABASE_AUTH_GITHUB_CLIENT_SECRET=YOUR_GITHUB_OAUTH_CLIENT_SECRET
GITHUB_OAUTH_CLIENT_ID=YOUR_GITHUB_OAUTH_CLIENT_ID
GITHUB_OAUTH_CLIENT_SECRET=YOUR_GITHUB_OAUTH_CLIENT_SECRET

# Optional build + runtime hooks ---------------------------------------------
REGISTRY=
GITHUB_TOKEN=
WEB3_WSS_URL=
CONTRACT_ADDRESS=
REDIS_URL=redis://redis:6379/0
AGENT_IMAGE=${REGISTRY}/engi-agent:latest

GITHUB_APP_ID=YOUR_GITHUB_APP_ID
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_GITHUB_APP_PRIVATE_KEY\n-----END PRIVATE KEY-----"

EXA_API_KEY=YOUR_EXA_API_KEY
TMP=/tmp

# Feature flags ---------------------------------------------------------------
NEXT_PUBLIC_MAINTENANCE_MODE=false
DRY_RUN_MODE=true
MCP_UPGRADES=true
NEXT_PUBLIC_SIDEBAR_UPGRADES=true
NEXT_PUBLIC_CONVERSATION_SECTION=false
NEXT_PUBLIC_DISABLE_USING=true
