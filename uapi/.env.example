# Environment Variables Example
# Copy this file to `.env.local` and fill in your values.

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=<your Supabase project URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your Supabase anon/public API key>

# Supabase OAuth Providers
SUPABASE_AUTH_GOOGLE_CLIENT_ID=<your Google OAuth client ID>
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=<your Google OAuth client secret>
SUPABASE_AUTH_GITHUB_CLIENT_ID=<your GitHub OAuth client ID>
SUPABASE_AUTH_GITHUB_CLIENT_SECRET=<your GitHub OAuth client secret>

# Supabase custom OAuth2 provider for Bitcode Bitcoin wallet authentication.
# The Supabase provider identifier is `custom:bitcode-bitcoin`.
BITCODE_BITCOIN_OAUTH_CLIENT_ID=bitcode-bitcoin-wallet
BITCODE_BITCOIN_OAUTH_CLIENT_SECRET=<same value configured as the custom provider client secret>
BITCODE_BITCOIN_OAUTH_ALLOWED_REDIRECT_ORIGINS=<your Supabase project origin, e.g. https://project-ref.supabase.co>
BITCODE_BITCOIN_OAUTH_ALLOWED_REDIRECT_URIS=<your Supabase auth callback URL, e.g. https://project-ref.supabase.co/auth/v1/callback>
BITCODE_BITCOIN_OAUTH_SUPABASE_CALLBACK_URL=<your Supabase auth callback URL>
NEXT_PUBLIC_BITCODE_BITCOIN_NETWORK=testnet4

# Supabase JWT secret (server-side)
SUPABASE_JWT_SECRET=<your Supabase JWT secret>

# OpenAI API key for chat and other AI-driven features
OPENAI_API_KEY=<your OpenAI secret key>

# Stripe (Payments)
# Secret key for Stripe API (server-side)
STRIPE_SECRET_KEY=<your Stripe secret key>
# Product ID for 'Industry' credit bundle (predefined)
STRIPE_PRODUCT_ID_INDUSTRY=<Stripe product ID for Industry plan>
# Product ID for 'Micro' credit bundle (predefined)
STRIPE_PRODUCT_ID_MICRO=<Stripe product ID for Micro plan>
# Product ID for the default Bitcode `$BTD` unit
STRIPE_PRODUCT_ID=<Stripe product ID representing one Bitcode `$BTD` unit>

# Credit system configuration
# Safety margin for credit reservations - when to top up (default: 10)
CREDIT_SAFETY_MARGIN=10
# Amount to top up when safety margin is reached (default: 100)
CREDIT_TOP_UP=100

# Feature flags (optional)
# Enable mocks for development and testing
NEXT_PUBLIC_ENABLE_MOCKS=true
# Enable mock responses for the chat stream
NEXT_PUBLIC_MOCK_CHAT_STREAM=true

# GA-1 Feature toggles - disable features not ready for production
# NEXT_PUBLIC_ENABLE_OTF_INSTRUCTIONS=true      # OTF instructions UI (default: false)
# NEXT_PUBLIC_ENABLE_ENHANCE_DOD=true           # Enhance DoD button (default: false)
# NEXT_PUBLIC_ENABLE_COMPUTE_TOGGLE=true        # Compute mode toggle (default: false)
# NEXT_PUBLIC_ENABLE_MULTI_AGENT_TOGGLE=true    # Multi-agent toggle (default: false)

# Contact form email settings
EMAIL_SMTP_URL=<your SMTP connection URL, e.g. smtp://user:pass@smtp.example.com:587>
CONTACT_SUPPORT_EMAIL=<your support email address>

# Integration OAuth configurations
# Notion OAuth (for workspace connections)
NOTION_CLIENT_ID=<your Notion OAuth client ID>
NOTION_CLIENT_SECRET=<your Notion OAuth client secret>
NOTION_REDIRECT_URI=<your domain>/api/integrations/notion/callback

# Figma OAuth (for design file access)
FIGMA_CLIENT_ID=<your Figma OAuth client ID>
FIGMA_CLIENT_SECRET=<your Figma OAuth client secret>
FIGMA_REDIRECT_URI=<your domain>/api/integrations/figma/callback

# GitLab OAuth (for repository access)
GITLAB_CLIENT_ID=<your GitLab OAuth client ID>
GITLAB_CLIENT_SECRET=<your GitLab OAuth client secret>
GITLAB_INSTANCE_URL=https://gitlab.com
GITLAB_REDIRECT_URI=<your domain>/api/integrations/gitlab/callback

# Bitbucket OAuth (for repository access)
BITBUCKET_CLIENT_ID=<your Bitbucket OAuth client ID>
BITBUCKET_CLIENT_SECRET=<your Bitbucket OAuth client secret>
BITBUCKET_REDIRECT_URI=<your domain>/api/integrations/bitbucket/callback

# GitHub App Integration (for repository access, NOT for SSO)
GITHUB_OAUTH_CLIENT_ID=<your GitHub App OAuth client ID>
GITHUB_OAUTH_CLIENT_SECRET=<your GitHub App OAuth client secret>
GITHUB_APP_ID=<your GitHub App ID>
GITHUB_PRIVATE_KEY=<your GitHub App private key (RSA format)>
GITHUB_WEBHOOK_SECRET=<webhook signature verification secret>
# Google Generative AI (Gemini)
GOOGLE_API_KEY=<your Google API key>
GEMINI_API_KEY=<your Gemini API key>
GOOGLE_GENERATIVE_AI_API_KEY=<your Google Generative AI key>

# Additional local development keys mirrored from `.env.local`.
AGENT_IMAGE=<agent container image>
ANTHROPIC_API_KEY=<your Anthropic API key>
AUTH_GITHUB_ID=<your GitHub auth client ID>
AUTH_GITHUB_SECRET=<your GitHub auth client secret>
BITCODE_LOG_FULL_PROMPTS=false
BITCODE_LOG_FULL_PROMPTS_CORRELATION_IDS=
CLERK_SECRET_KEY=<your Clerk secret key>
CONTRACT_ADDRESS=<development contract address>
DEBUG=false
DRY_RUN_MODE=false
EXA_API_KEY=<your Exa API key>
GITHUB_BITCODE_APP_CLIENT_SECRET=<your GitHub App client secret>
GITHUB_TOKEN=<your GitHub token>
GROQ_API_KEY=<your Groq API key>
HF_HUB_ENABLE_HF_TRANSFER=false
INSTALLTION_ID=<GitHub App installation ID>
MCP_UPGRADES=true
NEXT_PUBLIC_CONVERSATION_SECTION=false
NEXT_PUBLIC_DISABLE_USING=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_SIDEBAR_UPGRADES=false
NOTION_INTEGRATION_TOKEN=<your Notion integration token>
PINECONE_API_KEY=<your Pinecone API key>
REDIS_URL=<your Redis URL>
REGISTRY=<container registry>
REPLICATE_API_TOKEN=<your Replicate API token>
SCW_ACCESS_KEY=<your Scaleway access key>
SCW_DEFAULT_ORGANIZATION_ID=<your Scaleway organization ID>
SCW_DEFAULT_PROJECT_ID=<your Scaleway project ID>
SCW_SECRET_KEY=<your Scaleway secret key>
SUPABASE_PUBLISHABLE_KEY=<your Supabase publishable key>
SUPABASE_SECRET_KEY=<your Supabase secret key>
SUPABASE_SERVICE_ROLE_KEY=<your Supabase service role key>
SUPABASE_URL=<your Supabase project URL>
TMP=<local temporary directory>
TOKENIZERS_PARALLELISM=false
WEB3_WSS_URL=<your Web3 websocket URL>
