export const app = new App(config);

// iterate through all users signed up for Bitcode and fetch the repositories they've installed
/**
 * Returns all connected users' repositories by GitHub installation.
 */
export const getUsersRepositories = async () => {
  // Fetch all GitHub connections
  const { data: connections, error } = await supabaseAdmin
    .from('user_connections')
    .select('user_id, connection_data');
  if (error || !connections) {
    console.error('Error fetching user connections', error);
    return {};
  }
  const usersRepositories: Record<string, any> = {};
  for (const conn of connections) {
    const userId = conn.user_id;
    const installationId = conn.connection_data?.installationId;
    if (!installationId) continue;
    console.log(`🐲 Getting repositories for user ${userId} (installation ${installationId})...`);
    usersRepositories[userId] = { repositories: [] };
    for await (const { octokit, repository } of app.eachRepository.iterator({ installationId })) {
      usersRepositories[userId].repositories.push(repository);
    }
  }
  return usersRepositories;
};

export const getIssuesForRepository = async (installationId: number, repository: any) => {
  console.log(`🐲 Getting issues for repository ${repository.name}...`)
  const installationOctokit = await app.getInstallationOctokit(installationId)
  return (await installationOctokit.request("GET /repos/{owner}/{repo}/issues", {
    owner: repository.owner.login,
    repo: repository.name,
    headers: {
      'X-GitHub-Api-Version': '2022-11-28'
    }
  })).data;
}

export const getCommentsForIssue = async (installationId: number, repository: any, issue: any) => {
  console.log(`🐲 Getting comments for issue ${issue.title} on repository ${repository.name}...`)
  const installationOctokit = await app.getInstallationOctokit(installationId)
  return (await installationOctokit.request('GET /repos/{owner}/{repo}/issues/{issue_number}/comments', {
    owner: repository.owner.login,
    repo: repository.name,
    issue_number: issue.number,
    headers: {
      'X-GitHub-Api-Version': '2022-11-28'
    }
  })).data
}

export const leaveIssueComment = async (installationId: number, repository: any, issue: any, body: string) => {
  console.log(`🐲 Leaving comment on issue ${issue.title}...`)
  const installationOctokit = await app.getInstallationOctokit(installationId)
  await installationOctokit.request('POST /repos/{owner}/{repo}/issues/{issue_number}/comments', {
    owner: repository.owner.login,
    repo: repository.name,
    issue_number: issue.number,
    body,
    headers: {
      'X-GitHub-Api-Version': '2022-11-28'
    }
  })
}

export const downloadRepository = async (installationId: number, repository: any) => {
  console.log(`🐲 Downloading repository ${repository.name}...`)
  const installationOctokit = await app.getInstallationOctokit(installationId)
  const downloadUrl: string = (await installationOctokit.request('GET /repos/{owner}/{repo}/zipball/{ref}', {
    owner: repository.owner.login,
    repo: repository.name,
    ref: 'main',
    request: {
      parseSuccessResponseBody: false
    },
    headers: {
      'X-GitHub-Api-Version': '2022-11-28'
    }
  })).url

  const zipDirPath = path.join(os.homedir(), `.bitcode/memory/${repository.name}`)
  fs.mkdirSync(zipDirPath, { recursive: true })
  console.log(`🐲 Writing zip...`)
  const zipPath = path.join(zipDirPath, `${repository.name}.zip`)
  fs.writeFileSync(zipPath, Buffer.from(await (await fetch(downloadUrl)).arrayBuffer()))
  const unzipPath = path.join(os.homedir(), `.bitcode/memory/${repository.name}/${repository.name}`)
  console.log(`🐲 Decompressing zip...`)
  await decompress(zipPath, unzipPath)
  return unzipPath
}

export const createBranch = async (installationId: number, repository: any, name: string) => {
  console.log(`🐲 Creating branch ${name} on repository ${repository.name}...`)
  const installationOctokit = await app.getInstallationOctokit(installationId)
  const ref = (await installationOctokit.request('GET /repos/{owner}/{repo}/git/ref/{ref}', {
    owner: repository.owner.login,
    repo: repository.name,
    ref: 'heads/main',
    headers: {
      'X-GitHub-Api-Version': '2022-11-28'
    }
  })).data
  return (await installationOctokit.request('POST /repos/{owner}/{repo}/git/refs', {
    owner: repository.owner.login,
    repo: repository.name,
    ref: `refs/heads/${name}`,
    sha: ref.object.sha,
    headers: {
      'X-GitHub-Api-Version': '2022-11-28'
    }
  })).data
}
