{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "target": "es2020",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      // Keep the public prompt contract explicit on the active app path.
      // `@bitcode/prompts/*` covers approved subpaths such as
      // `raw_promptparts/*` and `formatters`, but we do not retain a
      // stable alias for `@bitcode/prompts/src/*`.
      "@bitcode/prompts": [
        "../packages/prompts/src/index.ts"
      ],
      "@bitcode/prompts/*": [
        "../packages/prompts/src/*"
      ],
      "@bitcode/prompts/raw_promptparts/*": [
        "../packages/prompts/src/raw_promptparts/*"
      ],
      "@bitcode/btd/terminal-operational-health": [
